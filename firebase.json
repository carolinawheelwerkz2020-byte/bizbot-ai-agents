{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/wheel-repair-raleigh",
        "destination": "/index.html"
      },
      {
        "source": "/wheel-repair-wake-forest",
        "destination": "/index.html"
      },
      {
        "source": "/wheel-repair-cary",
        "destination": "/index.html"
      },
      {
        "source": "/wheel-repair-durham",
        "destination": "/index.html"
      },
      {
        "source": "/wheel-repair-apex",
        "destination": "/index.html"
      },
      {
        "source": "/powder-coating-raleigh",
        "destination": "/index.html"
      },
      {
        "source": "/api/**",
        "function": "bizbot_server"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
