# GEMINI_API_KEY: Required for Gemini AI API calls and large-file uploads (Gemini File API — Google-hosted storage).
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Email Configuration (SMTP)
# Required for sending reports and summaries to user's inbox.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# --- Access control (Firebase Auth + server allowlist) ---
# Set VITE_FIREBASE_* from Firebase Console → Project settings → Your apps → Web app config.
# Enable Authentication: Email/Password and Google (or as needed). Create user accounts for you and workers.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated lowercase emails allowed to use the API (owner + workers). Empty = any signed-in Firebase user.
ALLOWED_EMAILS=

# Local dev: set to "true" to skip Bearer verification (no Firebase Admin credentials needed). Never use in production.
AUTH_DISABLED=true
