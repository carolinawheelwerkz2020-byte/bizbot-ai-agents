# GEMINI_API_KEY: Required for Gemini AI API calls and large-file uploads (Gemini File API — Google-hosted storage).
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional browser/client API base. Leave blank for same-origin `/api/*`.
# Set this when the frontend is hosted separately from the orchestration API.
VITE_API_BASE_URL=

# Email Configuration (SMTP)
# Required for sending reports and summaries to user's inbox.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# --- Access control (Firebase Auth + server allowlist) ---
# Set VITE_FIREBASE_* from Firebase Console → Project settings → Your apps → Web app config.
# Enable Authentication: Email/Password and Google (or as needed). Create user accounts for you and workers.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Carolina Wheel Werkz dashboard context ---
VITE_CWW_DASHBOARD_URL=https://update-cww-app.web.app/
VITE_CWW_FIREBASE_PROJECT_ID=carolinawheelwerkz
VITE_CWW_FIREBASE_PROJECT_NUMBER=797904737702
VITE_CWW_GCP_PARENT_ORG=carolinawheelwerkz2020-org

# --- Gmail estimate scanner (read-only OAuth) ---
# Required to let the BizBot app scan Gmail for estimate/quote leads.
# Use scope: https://www.googleapis.com/auth/gmail.readonly
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_REDIRECT_URI=http://localhost

# Comma-separated lowercase emails allowed to use the API (owner + workers). Empty = any signed-in Firebase user.
ALLOWED_EMAILS=

# Local dev: set to "true" to skip Bearer verification (no Firebase Admin credentials needed).
# In production (NODE_ENV=production, including Cloud Functions), auth is enforced unless you also set:
#   ALLOW_INSECURE_CLOUD_AUTH_BYPASS=true
# Never enable that bypass on a public deployment.
AUTH_DISABLED=true
ALLOW_INSECURE_CLOUD_AUTH_BYPASS=

# Production SPA builds: VITE_AUTH_DISABLED only bypasses Firebase Auth in dev unless you set:
#   VITE_ALLOW_INSECURE_CLOUD_AUTH_BYPASS=true
# (Same rule: never ship a public site with this enabled.)
VITE_ALLOW_INSECURE_CLOUD_AUTH_BYPASS=

# --- Multi-device execution architecture ---
# local-json keeps current desktop behavior. firestore moves shared app state to Firebase-backed adapters.
BIZBOT_STORAGE_MODE=local-json

# local-first keeps the current Mac/Desktop behavior. Set true when remote workers should be preferred.
BIZBOT_PREFER_REMOTE_WORKERS=false

# Optional: auto-approve selected autonomy actions when the requester already has approve-role privileges.
# Comma-separated values: register_tool,install_npm_package,save_healing_recipe,run_healing_recipe,self_heal_project,all
BIZBOT_AUTO_APPROVE_ACTIONS=

# Worker heartbeat timeout before a worker is shown as offline.
WORKER_HEARTBEAT_TTL_MS=45000

# Shared secret for trusted workers. Leave blank only for local dev fallback.
WORKER_API_KEY=

# Relay command policy for local/worker shell execution.
# Use "*" to allow any executable in PATH.
RELAY_ALLOWED_COMMANDS=npm,npx,node,git,tsx,tsc,vite,pnpm,yarn,bun,python,python3,pip,pip3,uv,make,sh,bash,zsh

# Set true to allow shell chaining/pipes (e.g. "npm run lint && npm test").
RELAY_ALLOW_SHELL_OPERATORS=false

# Execution fail-safes.
REMOTE_WORKER_TIMEOUT_MS=60000

# --- Worker client settings ---
# Point workers at the main BizBot API. For another machine, use the main server's LAN/VPN URL.
WORKER_MAIN_API_URL=http://localhost:3000
WORKER_ID=
WORKER_NAME=
WORKER_PORT=4317
WORKER_HOST=http://localhost:4317
WORKER_ROOT=
WORKER_ALLOWED_COMMANDS=npm,npx,node,git,tsx,tsc,vite,pnpm,yarn,bun,python,python3,pip,pip3,uv,make,sh,bash,zsh
WORKER_CAPABILITIES=shell,filesystem,git,npm,tool
WORKER_HEARTBEAT_MS=15000
WORKER_COMMAND_TIMEOUT_MS=60000
WORKER_NETWORK_TIMEOUT_MS=30000
